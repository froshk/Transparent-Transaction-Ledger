# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Stacks Blockchain Configuration
NEXT_PUBLIC_STACKS_NETWORK=testnet
NEXT_PUBLIC_STACKS_API_URL=https://stacks-node-api.testnet.stacks.co

# Application Configuration
NEXT_PUBLIC_APP_NAME="Transparent Transaction Ledger"
NEXT_PUBLIC_APP_DESCRIPTION="Blockchain-powered real estate transactions"

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_FEATURES=false
NEXT_PUBLIC_ENABLE_SMART_CONTRACTS=true

# Analytics (Optional)
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# NEXT_PUBLIC_MIXPANEL_TOKEN=
